# =============================================================================
# CareerProof AI — example environment variables
# =============================================================================
# Copy this file to `.env` (or set them on your host, e.g. Render) and fill
# in the values you actually want to use. EVERY variable below is optional
# from the client's perspective — the analytics module skips any provider
# whose env var is missing, so the app still runs without these set.

# -- Optional analytics / conversion tracking (client-side, must use VITE_) ---
# Meta (Facebook) Pixel ID. Enables PageView + funnel events + standard events.
VITE_META_PIXEL_ID=

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# PostHog project API key + host. Host defaults to https://us.i.posthog.com.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# -- Email delivery (server-side) ---------------------------------------------
# Used for password-reset codes AND post-preview feedback emails.
# EMAIL_PROVIDER=resend enables the Resend transactional API. EMAIL_API_KEY and
# EMAIL_FROM must also be set. Leave EMAIL_PROVIDER unset to fall back to
# RESET_DELIVERY_MODE=log (codes / feedback printed to the server console).
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM=
RESET_DELIVERY_MODE=

# -- Analysis feedback ---------------------------------------------------------
# Server-side recipient for the post-preview feedback survey. The client never
# sees or controls this; it can only POST { rating, comment, analysis_id }.
# Defaults to roqueta.alex@gmail.com if unset.
ANALYSIS_FEEDBACK_TO=

# -- Launch promo (server-side) -----------------------------------------------
# Time-limited launch offer: the first N customers can unlock the full AI
# Exposure Report for the discounted price below instead of the regular price.
# Only the single-credit "starter_1" package is discounted; multi-packs keep
# their catalog pricing.
#
# To turn the promo OFF without removing it, set LAUNCH_PROMO_ENABLED=0.
# The promo also auto-deactivates once LAUNCH_PROMO_LIMIT redemptions have
# been counted from the ledger (purchase rows tagged with `:promo=<name>`).
# Defaults below match the launch plan: 50 customers @ $1, regular price $3.
LAUNCH_PROMO_ENABLED=1
LAUNCH_PROMO_LIMIT=50
LAUNCH_PROMO_CREDIT_PRICE_CENTS=100
REGULAR_SINGLE_CREDIT_PRICE_CENTS=300
LAUNCH_PROMO_NAME=launch50
# Optional: a Stripe Price ID for the $1 promo. This build uses inline
# price_data, so this is currently informational only — set it if you
# manage prices in the Stripe Dashboard and want the env to record the
# corresponding promo price reference.
LAUNCH_PROMO_STRIPE_PRICE_ID=
