# =============================================================================
# CareerProof AI — example environment variables
# =============================================================================
# Copy this file to `.env` (or set them on your host, e.g. Render) and fill
# in the values you actually want to use. EVERY variable below is optional
# from the client's perspective — the analytics module skips any provider
# whose env var is missing, so the app still runs without these set.

# -- Optional analytics / conversion tracking (client-side, must use VITE_) ---
# Meta (Facebook) Pixel ID. Enables PageView + funnel events + standard events.
VITE_META_PIXEL_ID=

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# PostHog project API key + host. Host defaults to https://us.i.posthog.com.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# -- Email delivery (server-side) ---------------------------------------------
# Used for password-reset codes AND post-preview feedback emails.
# EMAIL_PROVIDER=resend enables the Resend transactional API. EMAIL_API_KEY and
# EMAIL_FROM must also be set. Leave EMAIL_PROVIDER unset to fall back to
# RESET_DELIVERY_MODE=log (codes / feedback printed to the server console).
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM=
RESET_DELIVERY_MODE=

# -- Analysis feedback ---------------------------------------------------------
# Server-side recipient for the post-preview feedback survey. The client never
# sees or controls this; it can only POST { rating, comment, analysis_id }.
# Defaults to roqueta.alex@gmail.com if unset.
ANALYSIS_FEEDBACK_TO=
